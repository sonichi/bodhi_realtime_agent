# Copy to .env and fill in only what you use.

# Core framework
GEMINI_API_KEY=
# OPENAI_API_KEY=
# LLM_PROVIDER=gemini

# Local server
HOST=0.0.0.0
PORT=9900

# Optional logging
# LOG_LEVEL=info
# LOG_FORMAT=text

# Optional auth/rate-limit/session controls (framework-level)
# AUTH_ENABLED=false
# AUTH_METHOD=anonymous
# MAX_SESSIONS_PER_USER=5
# MAX_TOTAL_SESSIONS=1000
# SESSION_TIMEOUT_MS=1800000
# CLEANUP_INTERVAL_MS=60000
# RATE_LIMITING_ENABLED=true
# RATE_LIMIT_REQUESTS_PER_MIN=60
# RATE_LIMIT_CONNECTIONS_PER_MIN=10

# Optional Supabase auth backend
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional Twilio inbound bridge (examples / telephony integrations)
# TWILIO_INBOUND_ENABLED=true
# TWILIO_WEBHOOK_URL=https://your-public-url.example.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# HUMAN_AGENT_PHONE=
# TWILIO_WEBHOOK_PORT=8766
# AGENT_WS_URL=ws://localhost:9900

# Optional Cartesia TTS demo
# CARTESIA_API_KEY=
# CARTESIA_VOICE_ID=
# CARTESIA_SPEED=normal
# CARTESIA_EMOTION=
# CARTESIA_MODEL_ID=sonic-2
# CARTESIA_LANGUAGE=en

# Optional OpenClaw examples
# OPENCLAW_URL=ws://127.0.0.1:18789
# OPENCLAW_TOKEN=
# OPENCLAW_HTTP_URL=
# OPENCLAW_HTTP_TOKEN=
# OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_MODEL=openclaw/default

# Optional web client host (example web clients)
# CLIENT_HOST=0.0.0.0
# CLIENT_PORT=8080

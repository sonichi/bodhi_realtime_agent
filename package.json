{
  "name": "bodhi-realtime-agent",
  "version": "0.1.3",
  "description": "Voice agent framework with parallel background subagents — your agent keeps talking while long-running tasks run in the background. Built on Gemini Live API.",
  "keywords": [
    "ai",
    "agent",
    "ai-agent",
    "voice",
    "voice-agent",
    "voice-ai",
    "realtime",
    "gemini",
    "gemini-live",
    "google",
    "framework",
    "agentic-framework",
    "background-tasks",
    "subagent",
    "multi-agent",
    "speech-to-speech",
    "conversational-ai"
  ],
  "homepage": "https://github.com/randombet/bodhi_realtime_agent#readme",
  "bugs": {
    "url": "https://github.com/randombet/bodhi_realtime_agent/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/randombet/bodhi_realtime_agent.git"
  },
  "license": "MIT",
  "author": "Yixuan Zhai",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --fix src/ test/",
    "typecheck": "tsc --noEmit",
    "prepare": "git config core.hooksPath .githooks",
    "prepublishOnly": "pnpm build && pnpm test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "typedoc && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.0",
    "@google/genai": "^1.41.0",
    "ai": "^4.3.0",
    "openai": "^6.25.0",
    "write-file-atomic": "^6.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/write-file-atomic": "^4.0.3",
    "@types/ws": "^8.5.0",
    "mermaid": "^11.12.2",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.6.4",
    "typedoc-vitepress-theme": "^1.1.2",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "protobufjs"
    ]
  }
}
